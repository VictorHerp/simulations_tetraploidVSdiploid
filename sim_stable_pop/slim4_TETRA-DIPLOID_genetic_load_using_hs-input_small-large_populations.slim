//pop1=p1;pop2=p2;mut=m1;sampSize=10;
function (s) getIndvSumm(o pop1,o pop2, o mut, i sampSize)
{
	indvCount=pop1.individualCount;
	individuals=pop1.sampleIndividuals(sampSize);
	out=c();
	for(individual in individuals){
		other = pop2.individuals[individual.tag];
		mutsp1=individual.uniqueMutationsOfType(mut);
		mutsp2=other.uniqueMutationsOfType(mut);
		muts=unique(c(mutsp1,mutsp2));
		Mutcount=size(muts);
		if(Mutcount==0){next;}
		counts=sapply(muts,"sum(individual.genomes.containsMutations(applyValue)) + sum(other.genomes.containsMutations(applyValue));");
		mut_hom=muts[counts==4];
		mut_het=muts[counts<4];
		counts_het=counts[counts<4];
		counts_homo=counts[counts==4]; // usando input_hs
		if(length(mut_hom)>0){s_hom=mut_hom.getValue("s");}else{s_hom=0;}
		//if(length(mut_hom)>0){s_hom=sapply(0:(length(counts_homo)-1),"mut_hom[applyValue].getValue('s')[counts_homo[applyValue]];");}else{s_hom=0;} // usando input_hs
		if(length(mut_het)>0){
			//s_het=mut_het.selectionCoeff;
			//s_het=sapply(0:(length(counts_het)-1),"mut_het[applyValue].getValue('s')[counts_het[applyValue]];"); // usando input_hs
			h_het=sapply(0:(length(counts_het)-1),"mut_het[applyValue].getValue('h')[counts_het[applyValue]];");
			s_het=mut_het.getValue("s"); // para tomar los valores s de hs-input despues de modificas HM-nov-22
		}else{s_het=0;h_het=0;}
		
		totalLoad=sum(abs(s_hom)) + sum(0.5*abs(s_het)); //aqui agregue abs a los valores de s_hom
		relzLoad=sum(abs(s_hom)) + sum(h_het*abs(s_het)); //aqui agregue abs a los valores de s_hom

		///////////////////MASKED LOAD FIXED//////////////////////////
		for(m in mut_het){ 
		m_h=sapply(0:(length(m)-1),"m[applyValue].getValue('h')[counts_het[applyValue]];");
		m_s=m.getValue("s");
		if(m_h < 0.5){m_mskLoad = (0.5-m_h)*abs(m_s);}else{m_mskLoad = 0;}		
		} 
		mskLoad=sum(m_mskLoad);

		//mskLoad=sum((0.5-h_het)*abs(s_het));
		//	sum(relzLoad+mskLoad)==totalLoad
		fitness=product(1-abs(s_hom)) * product(1-(h_het*abs(s_het)));
		//cached_fit=p1.cachedFitness(individual.index)/p1.getValue("scal");
		out=c(out,("K"+K+"_tetraploid" +"\t"+ sim.cycle +"\t"+ indvCount +"\t"+ individual.tag +"\t"+ Mutcount +"\t"+ totalLoad +"\t"+ relzLoad +"\t"+ mskLoad+"\t"+ fitness));
	}
	return(out);
}


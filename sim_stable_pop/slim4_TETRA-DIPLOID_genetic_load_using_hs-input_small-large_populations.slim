reproduction(p1) { ///// tetraploid reproduction/////
	mate = p1.sampleIndividuals(1, replace=T);
	ma_chroms = c(individual.genomes, p2.individuals[individual.tag].genomes);
	pa_chroms = c(mate.genomes, p2.individuals[mate.tag].genomes);
	ma_order = sample(seqLen(4), 4);
	pa_order = sample(seqLen(4), 4);
	breakpoints1 = sim.chromosome.drawBreakpoints();
	breakpoints2 = sim.chromosome.drawBreakpoints();
	offspring = p1.addRecombinant(ma_chroms[ma_order[0]], ma_chroms[ma_order[1]], breakpoints1,
		pa_chroms[pa_order[0]], pa_chroms[pa_order[1]], breakpoints2);
	breakpoints1 = sim.chromosome.drawBreakpoints();
	breakpoints2 = sim.chromosome.drawBreakpoints();
	other = p2.addRecombinant(ma_chroms[ma_order[2]], ma_chroms[ma_order[3]], breakpoints1,
		pa_chroms[pa_order[2]], pa_chroms[pa_order[3]], breakpoints2);
	tag = runif(1);
	offspring.tagF = tag;
	other.tagF = tag;
}
///////////////////////DIPLOID REPRODUCTION//////////////////
reproduction(p3) { 
	mate = p3.sampleIndividuals(1, replace=T); 
	ma_chroms = individual.genomes;
	pa_chroms = mate.genomes;
	ma_order = sample(seqLen(2), 2); 
	pa_order = sample(seqLen(2), 2);
	breakpoints1 = sim.chromosome.drawBreakpoints();
	breakpoints2 = sim.chromosome.drawBreakpoints();
	offspring = p3.addRecombinant(ma_chroms[ma_order[0]], ma_chroms[ma_order[1]], breakpoints1,
		pa_chroms[pa_order[0]], pa_chroms[pa_order[1]], breakpoints2);

}

/////////////////////DFE TETRAPLOID///////////////////////////
mutation(m1,p1){
	////////////h & s from burn-in file/////////////
	MUT=sample(0:mutCOUNT,1);//HM-nov-22
	selCoef=s[MUT];//HM-nov-22
	Xh=(h_copies[MUT]/N_copies[MUT]);
	Xh=c(0.0, Xh*1,Xh*2,Xh*3, 1.0);	
	mut.setValue("s", selCoef);
	mut.setValue("h", Xh);
	return T;
}
mutation(m1,p2){
	////////////h & s from burn-in file/////////////
	MUT=sample(0:mutCOUNT,1);
	selCoef=s[MUT];
	Xh=(h_copies[MUT]/N_copies[MUT]);
	Xh=c(0.0, Xh*1,Xh*2,Xh*3, 1.0);
	mut.setValue("s", selCoef);
	mut.setValue("h", Xh);
	return T;
}

/////////////////////DFE DIPLOID///////////////////////////
mutation(m2,p3){

	////////////h & s from burn-in file/////////////
	MUT=sample(0:mutCOUNT_dip,1);
	selCoef_dip=s_dip[MUT];
	dom=h_mut_dip[MUT];
	Xh_dip=c(0.0,dom,1.0);
	mut.setValue("s_dip", selCoef_dip);
	mut.setValue("h_dip", Xh_dip);
	
	return T;
}



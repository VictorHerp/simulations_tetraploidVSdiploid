initialize() {
	
	if (exists("mu")==0){
		defineConstant("mu",1e-9); // mutation rate 
	}
	
	if (exists("rho")==0){
		defineConstant("rho",1e-4); // recombination rate
	}
	
	if (exists("K")==0){
		defineConstant("K",40); // carrying capacity tetraploid
	}
	
	if (exists("Kdiploid")==0){
		defineConstant("Kdiploid",K*2); // carrying capacity diploid
	}
	
	if (exists("lastGen")==0){
		defineConstant("lastGen",30000); // last generation
	}
	
	if (exists("L")==0){
		defineConstant("L",200e6); // genomic element size
	}
	

/////////////////////////////////////////For output files////////////////////////////////////////////	
	defineConstant("start", time());
	defineConstant("outPath", "/PATH/TO/SAVE/OUTPUT/FILES");
	defineConstant("outName", start+"_"+"chr200M_tetra_"+"load_hs-input_burn100");
	defineConstant("outName_dip", start+"_"+"chr200M_diploid_"+"load_hs-input_burn100");
	defineConstant("outTimes",outPath+"/"+"TIME_"+outName+"_K"+K+"_seed"+getSeed()+"_lastGen"+lastGen);
	
	/////input deleterious DFE TETRAPLOID////	
	defineConstant("hs_input", "/PATH/WHERE/IS/HS-INPUT/FILE/Burn-in_hs-input_partial_recessive_mut_tetraploids.txt");
	defineConstant("del_mut", 1000); // number of deleterious mutation
	hs=readFile(hs_input);
	hs=hs[1:(length(hs)-1)];
	if((length(hs)-1)>del_mut){
		hs=hs[sample(0:(length(hs)-1),del_mut)];
	}
	
	defineConstant("mutCOUNT", length(hs)-1);
	
	defineConstant("s", asFloat(sapply(hs,"strsplit(applyValue,'\t')[4];")));
	defineConstant("h_copies", asFloat(sapply(hs,"strsplit(applyValue,'\t')[5];")));
	defineConstant("N_copies", asFloat(sapply(hs,"strsplit(applyValue,'\t')[6];")));
	
////////////////////input deleterious DFE DIPLOID//////////////////////////////////////////////////////////
	defineConstant("hs_input_dip", "/PATH/WHERE/IS/HS-INPUT/FILE/Burn-in_hs-input_partial_recessive_mut_diploids.txt");
	defineConstant("del_mut_dip", 1000); // number of deleterious mutation
	hs_dip=readFile(hs_input_dip);
	hs_dip=hs_dip[1:(length(hs_dip)-1)];
	if((length(hs_dip)-1)>del_mut_dip){
	hs_dip=hs_dip[sample(0:(length(hs_dip)-1),del_mut_dip)];
	}
	
	defineConstant("mutCOUNT_dip", length(hs_dip)-1);
	defineConstant("s_dip", asFloat(sapply(hs_dip,"strsplit(applyValue,'\t')[5];")));
	defineConstant("h_mut_dip", asFloat(sapply(hs_dip,"strsplit(applyValue,'\t')[6];")));

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	
	initializeSLiMModelType("nonWF");
	initializeMutationType("m1", 0.5, "f", 0.0);//// deleterious mutations in tetraploids but neutral in diploids (maintanied when fixed)
	m1.convertToSubstitution = F; 
	initializeMutationType("m2", 0.5, "f", 0.0);//// deleterious mutations in diploids but neutral in tetraploids (maintanied when fixed)
	m2.convertToSubstitution = F;
	
		
	initializeGenomicElementType("g1", c(m1,m2), c(0.5,0.5));
	initializeGenomicElement(g1, 0, L - 1);
	initializeMutationRate(mu);
	initializeRecombinationRate(1e-8);

}


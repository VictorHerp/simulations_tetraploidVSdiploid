		Mutcount=size(muts);
		if(Mutcount==0){next;}
		counts=sapply(muts,"sum(individual.genomes.containsMutations(applyValue)) + sum(other.genomes.containsMutations(applyValue));");
		mut_hom=muts[counts==4];
		mut_het=muts[counts<4];

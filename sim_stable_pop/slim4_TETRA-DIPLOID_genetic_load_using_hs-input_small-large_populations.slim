	HEAD_INDV="scenario" +"\t"+ "generation"+"\t"+ "indvCount" +"\t"+ "indiv.tag" + "\t"+"Mutcount" +"\t"+ "totalLoad" +"\t"+ "relzLoad" +"\t"+ "mskLoad"+"\t"+"fitness";
	HEAD_MUT2="generation"+"\t"+ "indiv.tag" +"\t"+ "Mutcount" +"\t"+ "fitness" +"\t"+ "s" +"\t"+ "h" +"\t"+ "counts_copy"+"\t"+"freq";
	

		if(length(mut_het)>0){
			//s_het=mut_het.selectionCoeff;
			//s_het=sapply(0:(length(counts_het)-1),"mut_het[applyValue].getValue('s')[counts_het[applyValue]];"); // usando input_hs
			s_het=mut_het.getValue("s"); // para tomar los valores s de hs-input despues de modificas HM-nov-22
			h_het=sapply(0:(length(counts_het)-1),"mut_het[applyValue].getValue('h')[counts_het[applyValue]];");
		}else{s_het=0;h_het=0;}
		if(length(mut_hom)>0){h_hom=rep(1.0,length(s_hom));}else{h_hom=0;} //agregado
		
		fitness=product(1-abs(s_hom)) * product(1-(h_het*abs(s_het)));
		
		het=rep("het",length(h_het));
		hom=rep("hom",length(s_hom));
		//if(s_hom>0){hom=hom;}else{hom="NULL";}
		h=c(h_het,rep(1,length(s_hom)));
		//counts=c(counts,rep(4,length(s_hom)));
		if(length(mut_hom)>0){counts_hom=rep(4,length(s_hom));}else{counts_hom="NULL";}
		
		//out=c(out,(sim.generation +"\t"+ individual.tag +"\t"+ Mutcount +"\t"+ fitness +"\t"+ paste(s_hom,sep=",") +"\t"+ paste(h_het,sep=",") +"\t"+ paste(s_het,sep=",") +"\t"+ paste(counts,sep=",")));
		
		out0=c(out0,(sim.cycle +"\t"+ individual.tag +"\t"+ Mutcount +"\t"+ fitness +"\t"+ s_het +"\t"+ h_het +"\t"+ counts_het +"\t"+freq_het));
		out1=c(out1,(sim.cycle +"\t"+ individual.tag +"\t"+ Mutcount +"\t"+ fitness +"\t"+ s_hom +"\t"+ h_hom +"\t"+ counts_hom +"\t"+freq_hom));
		out2=c(out0,out1);
	
	}

function (float) get_del_mutation_per_ind(lifso<Subpopulation> x)
{
	all_genomes = c(x.individuals,p2.individuals[x.individuals.tag]);
	all_muts = unique(all_genomes.genomes.mutationsOfType(m1));
	n_muts = 0;
	if(size(all_genomes) != 0){
		for(ind in x.individuals){
			counts_1 = ind.genomes.mutationCountsInGenomes(all_muts);
			counts_2 = p2.individuals[ind.tag].genomes.mutationCountsInGenomes(all_muts);
			all_counts = counts_1 + counts_2;
			n_muts = n_muts + size(which(all_counts != 0));
		}
		return n_muts / size(x.individuals);
	}
	else
		return 0.0;
}

////heterozygous per site
function (f) calc_Het_site(o pop, o mut) {
	heterozygousSites = 0;
	lenghtG = L;
	icount = pop.individualCount;
	Nalleles = icount * 4;
	Lr = L -1;
	ind = pop.individuals;
	others = p2.individuals[ind.tag];
	Gtetra = c(ind.genomes,others.genomes);
	Muts = size(Gtetra.mutationsOfType(mut));
	allelesPosition = sort(Gtetra.mutationsOfType(mut).position);
	
	for (site in 0:Lr) {
		
		if(Muts==0){next;}
		allelesSite = allelesPosition == site;
		allelesMut = sum(allelesSite);
		hetXsite= 1- (((allelesMut/Nalleles)^2) + (((Nalleles-allelesMut)/Nalleles)^2));
		heterozygousSites = c(heterozygousSites, hetXsite);
		totHet = sum(heterozygousSites);
	
	}
	totalHetXsite = totHet/lenghtG;
	return totalHetXsite;
}

function (s)getNeutHet (o pop, o mut, i sampSize) //// (s) is equal to string and (o) to objects
{
	total=0;
	sample = pop.sampleIndividuals(sampSize);
	out=c();
	for (ind in sample) {
		
		// Calculate the nucleotide heterozygosity of this individual
		TAG=ind.tagF;
		iP2=p2.individuals[p2.individuals.tagF==TAG];
		GENOMES=c(ind.genomes[0],ind.genomes[1],iP2.genomes[0],iP2.genomes[1]);
		
		pairwise_tetra=c(); //simile a total=0;
		for (i in 0:3){
			for (j in 0:3){
				if (i != j){
					muts0=GENOMES[i].mutationsOfType(mut);
					muts1=GENOMES[j].mutationsOfType(mut);
					//muts=unique(c(muts0,muts1));
					//Mutcount=size(muts);
					
					// Count the shared mutations
					shared_count = sum(match(muts0, muts1) >= 0);
					
					// All remaining mutations in the genomes are unshared (i.e. heterozygous)
					unshared_count = muts0.size() + muts1.size() - 2 * shared_count;
					
					// pi is the mean heterozygosity across the chromosome
					pi_i= unshared_count / (sim.chromosome.lastPosition + 1);
					//	print(i + "-" + j + "-" + pi_i);
					pairwise_tetra=c(pairwise_tetra,pi_i);
				}
			}
		}
		pi_individuals=mean(pairwise_tetra);
		total = total + pi_individuals;
	}
	pi = total/sampSize;
	Ne = pi/(8*mu);
	out = pi + "\t" + Ne;
	return(out);
}


/////////////////////////////////////FUNCTIONS DIPLOID///////////////////////////////////////
function (s) getIndvload_dip(o pop1, o mut, i sampSize)
{
	indvCount=pop1.individualCount;
	individuals=pop1.sampleIndividuals(sampSize);
	out=c();
	for(individual in individuals){
		muts=individual.uniqueMutationsOfType(mut);
		//mutsTrue=muts[muts.selectionCoeff<0];
		Mutcount=size(muts);
		if(Mutcount==0){next;}
		counts=sapply(muts,"sum(individual.genomes.containsMutations(applyValue));");
		mut_hom=muts[counts==2];
		mut_het=muts[counts<2];
		counts_het=counts[counts<2];		
		if(length(mut_hom)>0){s_hom=mut_hom.getValue("s_dip");}else{s_hom=0;}
		if(length(mut_het)>0){
			s_het=mut_het.getValue("s_dip");
			h_het=sapply(0:(length(counts_het)-1),"mut_het[applyValue].getValue('h_dip')[counts_het[applyValue]];");
		}else{s_het=0;h_het=0;}
		
		totalLoad=sum(abs(s_hom)) + sum(0.5*abs(s_het)); //aqui agregue abs a los valores de s_hom
		relzLoad=sum(abs(s_hom)) + sum(h_het*abs(s_het)); //aqui agregue abs a los valores de s_hom
		mskLoad=sum((0.5-h_het)*abs(s_het));
		//	sum(relzLoad+mskLoad)==totalLoad
		fitness=product(1-abs(s_hom)) * product(1-(h_het*abs(s_het)));
		//cached_fit=p1.cachedFitness(individual.index)/p1.getValue("scal");
		out=c(out,("K"+Kdiploid+"_diploid" +"\t"+ sim.cycle +"\t"+ indvCount +"\t"+ individual.index +"\t"+ Mutcount +"\t"+ totalLoad +"\t"+ relzLoad +"\t"+ mskLoad+"\t"+ fitness));
	}
	return(out);
}

//pop1=p1;mut1=m1;mut2=m2;sampSize=1;
function (s) getMutSurv_dip(o pop1,o mut1, i sampSize)
{
	indvCount=pop1.individualCount;
	individuals=pop1.sampleIndividuals(sampSize);
	out=c();
	out0=c();
	out1=c();
	for(individual in individuals){
		muts1=individual.uniqueMutationsOfType(mut1);
		//mutsTrue=muts1[muts1.selectionCoeff<0];
		Mutcount=size(muts1);
		if(Mutcount==0){next;}
		counts=sapply(muts1,"sum(individual.genomes.containsMutations(applyValue));");
		mut_hom=muts1[counts==2];
		mut_het=muts1[counts<2];
		counts_het=counts[counts<2];
		freq_het=sim.mutationFrequencies(pop1, mut_het);
		if(length(mut_hom)>0){freq_hom=sim.mutationFrequencies(pop1, mut_hom);}else{freq_hom=0;}
		
		if(length(mut_hom)>0){s_hom=mut_hom.getValue("s_dip");}else{s_hom=0;}
		//s_hom=mut_hom.getValue("s");
		if(length(mut_het)>0){
			s_het=mut_het.getValue("s_dip");
			//h_het=mut_het.getValue("dom");
			h_het=sapply(0:(length(counts_het)-1),"mut_het[applyValue].getValue('h_dip')[counts_het[applyValue]];"); 
		}else{s_het=0;h_het=0;}
		if(length(mut_hom)>0){h_hom=rep(1.0,length(s_hom));}else{h_hom=0;} //agregado
		
		fitness=product(1-abs(s_hom)) * product(1-(h_het*abs(s_het)));
		
		het=rep("het",length(h_het));
		hom=rep("hom",length(s_hom));
		//if(s_hom>0){hom=hom;}else{hom="NULL";}
		h=c(h_het,rep(1.0,length(s_hom)));
		//counts=c(counts,rep(2,length(s_hom)));
		if(length(mut_hom)>0){counts_hom=rep(2,length(s_hom));}else{counts_hom="NULL";} 
		
		//out=c(out,(sim.cycle+"\t"+individual.index +"\t"+ Mutcount +"\t"+ fitness+"\t"+ c(het,hom) +"\t"+ c(s_het,s_hom) +"\t"+ h +"\t"+ c(freq_het,freq_hom)));
		out0=c(out0,(sim.cycle +"\t"+ individual.index +"\t"+ Mutcount +"\t"+ fitness +"\t"+ s_het +"\t"+ h_het +"\t"+ counts_het+"\t"+ freq_het));
		out1=c(out1,(sim.cycle +"\t"+ individual.index +"\t"+ Mutcount +"\t"+ fitness +"\t"+ s_hom +"\t"+ h_hom +"\t"+ counts_hom+"\t"+ freq_hom));
		out2=c(out0,out1);
	
	
	}
	return(out2);

}


////heterozygous per site
function (f) calc_Het_site_dip(o pop, o mut) {
	heterozygousSites = 0;
	lenghtG = L;
	icount = pop.individualCount;
	Nalleles = icount * 2;
	Lr = L -1;
	ind = pop.individuals;
	genomes = ind.genomes;
	Muts = size(genomes.mutationsOfType(mut));
	allelesPosition = sort(genomes.mutationsOfType(mut).position);
	
	for (site in 0:Lr) {
		
		if(Muts==0){next;}
		allelesSite = allelesPosition == site;
		allelesMut = sum(allelesSite);
		hetXsite= 1- (((allelesMut/Nalleles)^2) + (((Nalleles-allelesMut)/Nalleles)^2));
		heterozygousSites = c(heterozygousSites, hetXsite);
		totHet = sum(heterozygousSites);
	
	}
	totalHetXsite = totHet/lenghtG;
	return totalHetXsite;
}

//// function for heterozygosity

function (s)getNeutHet_dip (o pop, o mut, i sampSize) //// (s) is equal to string and (o) to objects
{
	
	total = 0.0;
	sample = pop.sampleIndividuals(sampSize);
	
	for (ind in sample)
	{
		// Calculate the nucleotide heterozygosity of this individual
		muts0 = ind.genomes[0].mutationsOfType(mut);
		muts1 = ind.genomes[1].mutationsOfType(mut);
		
		// Count the shared mutations 
		shared_count = sum(match(muts0, muts1) >= 0);
		
		// All remaining mutations in the genomes are unshared (i.e. heterozygous)
		unshared_count = muts0.size() + muts1.size() - 2 * shared_count;
		
		// pi is the mean heterozygosity across the chromosome
		pi_ind = unshared_count / (sim.chromosome.lastPosition + 1);
		total = total + pi_ind;
	}
	
	pi = total/sampSize;
	Ne = pi / (4*mu);
	out = pi + "\t" + Ne;
	return out;
	
}
